{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Screen Manager API",
  "theme": "mint",
  "logo": {
    "light": "/logo_light.svg",
    "dark": "/logo_light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#7060e8",
    "light": "#7060e8",
    "dark": "#7060e8"
  },
  "topbarLinks": [
    {
      "name": "Support",
      "url": "mailto:support@framen.com"
    },
    {
      "name": "Login",
      "url": "https://dashboard.framen.com/login"
    }
  ],
  "topbarCtaButton": {
    "name": "Dashboard",
    "url": "https://dashboard.framen.com",
    "arrow": true
  },
  "api": {
    "baseUrl": "https://api.framen.com"
  },
  "openapi": "openapi.json",
  "redirects": [
    {
      "source": "/",
      "destination": "/api-reference/introduction"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Screen Manager",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "api-reference/introduction",
              "authentication"
            ]
          },
          {
            "group": "Locations",
            "pages": [
              "api-reference/locations/overview",
              "api-reference/locations/create",
              "api-reference/locations/get",
              "api-reference/locations/update",
              "api-reference/locations/list"
            ]
          },
          {
            "group": "Data types",
            "pages": [
              "api-reference/data-formats/opening-168",
              "api-reference/data-formats/visitors-7"
            ]
          },
          {
            "group": "Screens",
            "pages": [
              "api-reference/screens/overview",
              "api-reference/screens/create",
              "api-reference/screens/get",
              "api-reference/screens/update",
              "api-reference/screens/list"
            ]
          },
          {
            "group": "Venue Types",
            "pages": [
              "api-reference/venue-types/overview",
              "api-reference/venue-types/list"
            ]
          },
          {
            "group": "Ad Delivery",
            "pages": [
              "api-reference/ad-delivery/get-spot",
              "api-reference/ad-delivery/proof-of-play"
            ]
          },
          {
            "group": "Creatives",
            "pages": [
              "api-reference/creative-approvals/overview",
              "api-reference/creative-approvals/list-all",
              "api-reference/creative-approvals/list-active",
              "api-reference/creative-approvals/get",
              "api-reference/creative-approvals/approve",
              "api-reference/creative-approvals/reject"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://dashboard.framen.com/"
      }
    ]
  },
  "interaction": {
    "drilldown": true
  },
  "metadata": {
    "timestamp": true
  },
  "background": {
    "color": {
      "dark": "#000000",
      "light": "#ffffff"
    },
    "decoration": "grid"
  },
  "appearance": {
    "default": "system"
  }
}
